{
    "name": "sra/sratix-client",
    "description": "SRAtix Client WordPress Plugin",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "brain/monkey": "^2.6",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "classmap": ["includes/"]
    },
    "scripts": {
        "test": "phpunit --testsuite unit",
        "test:unit": "phpunit --testsuite unit",
        "test:all": "phpunit"
    },
    "config": {
        "allow-plugins": {}
    }
}
