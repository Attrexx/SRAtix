{
    "name": "taros/sratix-control",
    "description": "SRAtix Control WordPress connector",
    "type": "wordpress-plugin",
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "brain/monkey": "^2.7",
        "mockery/mockery": "^1.6"
    },
    "autoload": {
        "classmap": [
            "includes/"
        ]
    },
    "scripts": {
        "test": "phpunit --testsuite unit",
        "test:unit": "phpunit --testsuite unit"
    },
    "config": {
        "allow-plugins": {}
    }
}