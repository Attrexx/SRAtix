# SRAtix Server — Environment Variables
# Copy to .env and fill in real values.

# MariaDB
DATABASE_URL=mysql://user:password@host:3306/dbname

# Upstash Redis (TLS)
REDIS_URL=rediss://default:token@host.upstash.io:6379

# JWT secrets (generate with: node -e "console.log(require('crypto').randomBytes(36).toString('base64url'))")
JWT_SECRET=
JWT_REFRESH_SECRET=

# WP ↔ Server HMAC shared secret (must match WP plugin settings)
WP_API_SECRET=

# Webhook signing secret (Server → WP direction; must match sratix_webhook_secret WP option)
WEBHOOK_SIGNING_SECRET=

# SRA WordPress site URL (for member credential verification proxy)
SRA_WP_URL=https://swiss-robotics.org

# Server config
NODE_ENV=development
PORT=3000

# Stripe — set both test & live key pairs; STRIPE_MODE selects which is active
STRIPE_MODE=test
STRIPE_TEST_SECRET_KEY=sk_test_...
STRIPE_TEST_PUBLISHABLE_KEY=pk_test_...
STRIPE_LIVE_SECRET_KEY=sk_live_...
STRIPE_LIVE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Deploy key — used for CLI/CI rebuild notifications (X-Deploy-Key header)
DEPLOY_KEY=

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com
